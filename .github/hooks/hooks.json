{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/validate-immutable-paths.sh",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/validate-immutable-paths.ps1",
        "timeout": 10,
        "description": "Block any write operations targeting /standards/ or /exemplars/"
      },
      {
        "type": "command",
        "command": ".github/hooks/scripts/validate-bash-safety.sh",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/validate-bash-safety.ps1",
        "timeout": 10,
        "description": "Block shell writes to /standards/ and /exemplars/, and git push/merge (human-only)"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/log-tool-use.sh",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/log-tool-use.ps1",
        "timeout": 15,
        "description": "Append a structured entry to wiki/log.md after every tool invocation that writes a file"
      },
      {
        "type": "command",
        "command": ".github/hooks/scripts/check-code-quality.sh",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/check-code-quality.ps1",
        "timeout": 30,
        "description": "Lightweight quality lint on written source files: merge-conflict markers, debug statements, unannotated TODOs"
      }
    ]
  }
}
