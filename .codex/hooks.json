{
    "_comment":  "Generated by tools/setup-hooks.ps1 for Windows. Re-run after switching OS. Codex sends the same stdin JSON + exit-2 protocol; the shared .github guard scripts apply.",
    "hooks":  {
                  "PreToolUse":  [
                                     {
                                         "matcher":  "apply_patch|Edit|Write",
                                         "hooks":  [
                                                       {
                                                           "type":  "command",
                                                           "command":  "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/validate-immutable-paths.ps1",
                                                           "timeout":  10,
                                                           "statusMessage":  "Guarding /standards/ + /exemplars/ (read-only)"
                                                       }
                                                   ]
                                     },
                                     {
                                         "matcher":  "Bash",
                                         "hooks":  [
                                                       {
                                                           "type":  "command",
                                                           "command":  "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/validate-bash-safety.ps1",
                                                           "timeout":  10,
                                                           "statusMessage":  "Blocking writes to immutable paths + git push/merge (human-only)"
                                                       }
                                                   ]
                                     }
                                 ],
                  "PostToolUse":  [
                                      {
                                          "matcher":  "apply_patch|Edit|Write",
                                          "hooks":  [
                                                        {
                                                            "type":  "command",
                                                            "command":  "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/log-tool-use.ps1",
                                                            "timeout":  15,
                                                            "statusMessage":  "Appending to wiki/log.md"
                                                        },
                                                        {
                                                            "type":  "command",
                                                            "command":  "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/check-code-quality.ps1",
                                                            "timeout":  30,
                                                            "statusMessage":  "Quality lint on written files"
                                                        }
                                                    ]
                                      }
                                  ]
              }
}